@model IEnumerable<CMS.Data.Entities.Post>

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Danh Sách Bài Viết";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom border-danger">
        <h2 class="mb-0 text-danger font-weight-bold text-uppercase tracking-wide">
            <i class="bi bi-journal-text me-2"></i>Danh Sách Bài Viết
        </h2>
        <div>
            <a asp-action="Create" class="btn btn-success me-3">
                <i class="bi bi-plus-circle"></i> Thêm bài viết mới
            </a>
            <span class="badge bg-secondary px-3 py-2 fs-6">Tổng số: @Model.Count() bài viết</span>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-warning text-center py-5 shadow-sm rounded-lg" role="alert">
            <i class="bi bi-exclamation-triangle-fill fs-1 text-warning mb-3 d-block"></i>
            <h4 class="alert-heading">Không có bài viết nào!</h4>
            <p class="mb-0 text-muted">Chưa có bài viết nào thuộc danh mục này trong cơ sở dữ liệu.</p>
            <a href="/Category" class="btn btn-primary mt-3">
                <i class="bi bi-arrow-left me-1"></i> Quay lại Danh mục
            </a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 border-0 shadow-sm transition-card hover-shadow">
                        <div class="position-relative">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" class="card-img-top" alt="@item.Title" style="height: 220px; object-fit: cover;">
                            }
                            else
                            {
                                <div class="bg-light d-flex align-items-center justify-content-center" style="height: 220px;">
                                    <i class="bi bi-image text-muted" style="font-size: 3rem;"></i>
                                </div>
                            }
                            <span class="position-absolute top-0 start-0 m-3 badge bg-info text-dark px-3 py-2 shadow-sm font-weight-bold">
                                <i class="bi bi-tag-fill me-1"></i>@item.Category?.Name
                            </span>
                        </div>
                        <div class="card-body d-flex flex-column p-4">
                            <h5 class="card-title text-primary font-weight-bold mb-3 line-clamp-2" style="height: 3rem; overflow: hidden;">
                                @item.Title
                            </h5>
                            <p class="card-text text-muted mb-4 line-clamp-3" style="height: 4.5rem; overflow: hidden; font-size: 0.95rem;">
                                @item.Content
                            </p>
                            <div class="mt-auto pt-3 border-top border-light">
                                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                                    <small class="text-muted me-2">
                                        <i class="bi bi-calendar3 me-1"></i> @item.CreatedDate.ToString("dd/MM/yyyy")
                                    </small>
                                    <div class="btn-group" role="group">
                                        <a href="/Post/Details/@item.Id" class="btn btn-outline-primary btn-sm px-3 rounded-pill">
                                            Xem chi tiết
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm">
                                            Sửa
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm" onclick="return confirm('Chúng ta có chắc chắn muốn xóa bài viết này không?')">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .transition-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .hover-shadow:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1.5rem rgba(0,0,0,.15)!important;
    }
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
