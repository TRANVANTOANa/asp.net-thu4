@model CMS.Data.Entities.Post

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Cập Nhật Bài Viết";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-9">
            <div class="card border-0 shadow-lg rounded-lg">
                <div class="card-header bg-warning text-dark text-center py-4 rounded-top">
                    <h3 class="card-title mb-0 text-uppercase font-weight-bold">
                        <i class="bi bi-pencil-square me-2"></i>Cập Nhật Bài Viết
                    </h3>
                    <p class="mb-0 mt-1" style="color:rgba(0,0,0,.6);">Chỉnh sửa nội dung và thông tin bài đăng dưới đây</p>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post" enctype="multipart/form-data" class="needs-validation">
                        <input type="hidden" asp-for="Id" />
                        
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger rounded mb-4">
                                <i class="bi bi-exclamation-triangle me-2"></i><strong>Có lỗi trong quá trình lưu:</strong>
                                <ul class="mb-0 mt-2">
                                    @foreach (var ms in ViewData.ModelState.Values)
                                    {
                                        @foreach (var err in ms.Errors)
                                        {
                                            <li>@err.ErrorMessage</li>
                                        }
                                    }
                                </ul>
                            </div>
                        }

                        <div class="row">
                            <!-- Left Column -->
                            <div class="col-md-8">
                                <div class="mb-3">
                                    <label class="form-label font-weight-bold text-secondary">
                                        Tiêu Đề Bài Viết <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light text-secondary"><i class="bi bi-fonts"></i></span>
                                        <input asp-for="Title" class="form-control" required />
                                    </div>
                                    <span asp-validation-for="Title" class="text-danger small"></span>
                                </div>
                                <div class="mb-4">
                                    <label class="form-label font-weight-bold text-secondary">
                                        Nội Dung Chi Tiết <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light text-secondary"><i class="bi bi-text-paragraph"></i></span>
                                        <textarea asp-for="Content" class="form-control" rows="11" required></textarea>
                                    </div>
                                    <span asp-validation-for="Content" class="text-danger small"></span>
                                </div>
                            </div>
                            
                            <!-- Right Column -->
                            <div class="col-md-4 border-start border-light ps-md-4">
                                <div class="mb-3">
                                    <label class="form-label font-weight-bold text-secondary">
                                        Chuyên Mục <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light text-secondary"><i class="bi bi-folder2-open"></i></span>
                                        <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryList" required>
                                            <option value="">-- Chọn danh mục --</option>
                                        </select>
                                    </div>
                                </div>
                                
                                <div class="mb-3">
                                    <label class="form-label font-weight-bold text-secondary">Thay Đổi Ảnh</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light text-secondary"><i class="bi bi-upload"></i></span>
                                        <input type="file" name="uploadImage" class="form-control" accept="image/*" />
                                    </div>
                                </div>
                                
                                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                                {
                                    <div class="mb-3">
                                        <label class="form-label font-weight-bold text-secondary">Ảnh Hiện Tại</label>
                                        <div class="text-center bg-light p-2 rounded border border-light">
                                            <img src="@Model.ImageUrl" class="img-fluid rounded" alt="Ảnh hiện tại" style="max-height: 120px;" />
                                        </div>
                                    </div>
                                }
                                
                                <div class="mb-3">
                                    <label class="form-label font-weight-bold text-secondary">Link Ảnh (URL)</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light text-secondary"><i class="bi bi-link"></i></span>
                                        <input asp-for="ImageUrl" class="form-control" />
                                    </div>
                                </div>
                                
                                <div class="mb-4">
                                    <label class="form-label font-weight-bold text-secondary">Ngày Đăng</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light text-secondary"><i class="bi bi-calendar-event"></i></span>
                                        <input asp-for="CreatedDate" type="date" class="form-control" required />
                                    </div>
                                </div>
                                
                                <div class="d-grid gap-2 mt-4 pt-3 border-top border-light">
                                    <button type="submit" class="btn btn-warning text-dark rounded-pill shadow-sm font-weight-bold">
                                        <i class="bi bi-save-fill me-1"></i> Cập nhật thay đổi
                                    </button>
                                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill">
                                        <i class="bi bi-arrow-left me-1"></i> Quay lại
                                    </a>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .border-start { border-color: #f1f3f5 !important; }
    .rounded-lg  { border-radius: 16px !important; }
    .rounded-top { border-top-left-radius: 16px !important; border-top-right-radius: 16px !important; }
</style>