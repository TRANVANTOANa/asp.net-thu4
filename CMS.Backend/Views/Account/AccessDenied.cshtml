@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Không có quyền truy cập";
}

<div class="text-center py-5">
    <div class="mb-4">
        <i class="bi bi-shield-x" style="font-size: 5rem; color:#dc3545;"></i>
    </div>
    <h1 class="display-5 fw-bold text-danger">403</h1>
    <h2 class="h4 mb-3">Không có quyền truy cập</h2>
    <p class="text-muted mb-4">
        Bạn không có đủ quyền hạn để xem trang này.<br />
        Vui lòng liên hệ quản trị viên nếu bạn cho rằng đây là nhầm lẫn.
    </p>
    <a asp-controller="Home" asp-action="Index" class="btn btn-primary me-2">
        <i class="bi bi-house me-1"></i>Quay lại trang chủ
    </a>
    <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-secondary">
        <i class="bi bi-box-arrow-right me-1"></i>Đăng xuất
    </a>
</div>
