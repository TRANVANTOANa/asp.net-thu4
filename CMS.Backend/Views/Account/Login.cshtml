@{
    Layout = null; // Trang đăng nhập độc lập, không dùng Layout chung
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - ThaiCMS Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

        * { font-family: 'Inter', sans-serif; }

        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-card {
            width: 420px;
            border: none;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 25px 60px rgba(0,0,0,0.5);
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255,255,255,0.1);
        }

        .login-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            padding: 36px 32px 28px;
            text-align: center;
        }

        .login-header .logo-icon {
            width: 64px;
            height: 64px;
            background: rgba(255,255,255,0.2);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 16px;
            font-size: 28px;
        }

        .login-header h4 {
            color: white;
            font-weight: 700;
            font-size: 1.3rem;
            margin: 0;
            letter-spacing: 0.5px;
        }

        .login-header p {
            color: rgba(255,255,255,0.75);
            font-size: 0.85rem;
            margin: 6px 0 0;
        }

        .login-body {
            padding: 32px;
        }

        .form-label {
            color: rgba(255,255,255,0.8);
            font-size: 0.85rem;
            font-weight: 500;
            margin-bottom: 6px;
        }

        .input-group-text {
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.15);
            border-right: none;
            color: rgba(255,255,255,0.5);
        }

        .form-control {
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.15);
            border-left: none;
            color: white;
            padding: 11px 14px;
            border-radius: 0 8px 8px 0;
            transition: all 0.2s;
        }

        .form-control:focus {
            background: rgba(255,255,255,0.12);
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102,126,234,0.25);
            color: white;
        }

        .form-control::placeholder { color: rgba(255,255,255,0.3); }

        .btn-login {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            border-radius: 8px;
            padding: 12px;
            font-weight: 600;
            font-size: 0.95rem;
            letter-spacing: 0.5px;
            transition: all 0.3s;
            box-shadow: 0 4px 20px rgba(102,126,234,0.4);
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 30px rgba(102,126,234,0.6);
        }

        .btn-login:active { transform: translateY(0); }

        .alert-danger {
            background: rgba(220, 53, 69, 0.15);
            border: 1px solid rgba(220, 53, 69, 0.4);
            color: #ff6b7a;
            border-radius: 8px;
            font-size: 0.875rem;
        }

        .login-footer {
            text-align: center;
            color: rgba(255,255,255,0.35);
            font-size: 0.78rem;
            padding: 0 32px 24px;
        }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="login-header">
            <div class="logo-icon">
                <i class="bi bi-shield-lock-fill text-white"></i>
            </div>
            <h4>HỆ THỐNG QUẢN TRỊ CMS</h4>
            <p>Vui lòng đăng nhập để tiếp tục</p>
        </div>

        <div class="login-body">
            <form asp-action="Login" method="post">
                <div class="mb-4">
                    <label class="form-label">
                        <i class="bi bi-person me-1"></i>Tên đăng nhập
                    </label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-person"></i></span>
                        <input type="text" name="username" class="form-control"
                               placeholder="Nhập tên đăng nhập" required autocomplete="username" />
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label">
                        <i class="bi bi-lock me-1"></i>Mật khẩu
                    </label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-lock"></i></span>
                        <input type="password" name="password" class="form-control"
                               placeholder="Nhập mật khẩu" required autocomplete="current-password" />
                    </div>
                </div>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger py-2 mb-3">
                        <i class="bi bi-exclamation-circle me-1"></i>@ViewBag.Error
                    </div>
                }

                <button type="submit" class="btn btn-primary btn-login w-100 text-white">
                    <i class="bi bi-box-arrow-in-right me-2"></i>ĐĂNG NHẬP
                </button>
            </form>
        </div>

        <div class="login-footer">
            &copy; @DateTime.Now.Year ThaiCMS &mdash; Hệ thống quản trị nội dung
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
