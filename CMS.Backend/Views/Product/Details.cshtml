@model CMS.Data.entities.Product

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chi Tiết Sản Phẩm";
}

<div class="container mt-5">
    <div class="row">
        <!-- Cột trái: Hình ảnh sản phẩm -->
        <div class="col-lg-5 mb-4">
            <div class="card border-0 shadow-lg rounded-lg overflow-hidden position-relative">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid" style="width: 100%; object-fit: cover; min-height: 400px;">
                }
                else
                {
                    <div class="bg-light d-flex flex-column align-items-center justify-content-center" style="min-height: 400px;">
                        <i class="bi bi-image text-muted" style="font-size: 5rem;"></i>
                        <p class="text-muted mt-3">Sản phẩm chưa có hình ảnh</p>
                    </div>
                }
                <div class="position-absolute top-0 end-0 m-3">
                    <span class="badge @(Model.StockQuantity > 10 ? "bg-success" : Model.StockQuantity > 0 ? "bg-warning text-dark" : "bg-danger") px-3 py-2 shadow-sm rounded-pill font-weight-bold">
                        <i class="bi bi-box-seam me-1"></i> Tồn kho: @Model.StockQuantity
                    </span>
                </div>
            </div>
        </div>

        <!-- Cột phải: Thông tin chi tiết -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-lg rounded-lg h-100">
                <div class="card-header bg-white border-bottom-0 pt-4 px-4 pb-0">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <span class="text-uppercase text-primary fw-bold small tracking-wider">Mã SP: #@Model.Id</span>
                            <h2 class="display-6 fw-bold mt-1 mb-0">@Model.Name</h2>
                        </div>
                        <div class="dropdown">
                            <button class="btn btn-light btn-sm rounded-circle shadow-sm" type="button" data-bs-toggle="dropdown">
                                <i class="bi bi-three-dots-vertical"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                <li><a class="dropdown-item" href="@Url.Action("Edit", "Product", new { id = Model.Id })"><i class="bi bi-pencil me-2"></i>Chỉnh sửa</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="@Url.Action("Delete", "Product", new { id = Model.Id })" onclick="return confirm('Xóa sản phẩm này?')"><i class="bi bi-trash me-2"></i>Xóa</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
                
                <div class="card-body p-4">
                    <div class="mb-4">
                        <h3 class="text-success fw-bold display-5 mb-0">@Model.Price.ToString("N0") <small class="fs-4">VNĐ</small></h3>
                        <p class="text-muted small mt-1"><i class="bi bi-tag-fill me-1"></i> Chuyên mục: <strong>@Model.CategoryProduct?.Name</strong></p>
                    </div>

                    <div class="detail-section mb-4">
                        <h6 class="text-uppercase text-secondary fw-bold mb-3 small border-bottom pb-2">Mô tả sản phẩm</h6>
                        <div class="product-description text-secondary">
                            @if (!string.IsNullOrEmpty(Model.Description))
                            {
                                @Html.Raw(Model.Description)
                            }
                            else
                            {
                                <p class="fst-italic opacity-50">Sản phẩm này chưa được bổ sung mô tả chi tiết.</p>
                            }
                        </div>
                    </div>

                    <!-- Hành động -->
                    <div class="d-flex gap-3 mt-auto pt-4 border-top">
                        <a href="@Url.Action("Edit", "Product", new { id = Model.Id })" class="btn btn-warning px-4 py-2 rounded-pill font-weight-bold shadow-sm">
                            <i class="bi bi-pencil-fill me-1"></i> Chỉnh sửa thông tin
                        </a>
                        <a href="@Url.Action("Index", "Product")" class="btn btn-outline-secondary px-4 py-2 rounded-pill">
                            <i class="bi bi-arrow-left me-1"></i> Quay lại
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-lg { border-radius: 1.25rem !important; }
    .tracking-wider { letter-spacing: 0.1em; }
    .product-description { line-height: 1.6; }
    .fw-600 { font-weight: 600; }
</style>
