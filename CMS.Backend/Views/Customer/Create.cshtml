@model CMS.Data.entities.Customer

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Thêm Khách Hàng Mới";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-9 col-lg-8">
            <div class="card border-0 shadow-lg rounded-lg">
                <div class="card-header bg-primary text-white text-center py-4 rounded-top">
                    <h3 class="card-title mb-0 text-uppercase font-weight-bold">
                        <i class="bi bi-person-plus-fill me-2"></i>Thêm Khách Hàng Mới
                    </h3>
                    <p class="mb-0 text-white-50 mt-1">Điền thông tin bên dưới để đăng ký khách hàng mới</p>
                </div>
                <div class="card-body p-4">
                    <form method="post" class="needs-validation">
                        @Html.AntiForgeryToken()

                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger rounded mb-4">
                                <i class="bi bi-exclamation-triangle me-2"></i><strong>Có lỗi trong quá trình lưu:</strong>
                                <ul class="mb-0 mt-2">
                                    @foreach (var ms in ViewData.ModelState.Values)
                                    {
                                        @foreach (var err in ms.Errors)
                                        {
                                            <li>@err.ErrorMessage</li>
                                        }
                                    }
                                </ul>
                            </div>
                        }

                        <div class="row">
                            <!-- Tên khách hàng -->
                            <div class="col-md-6 mb-3">
                                <label for="FullName" class="form-label font-weight-bold text-secondary">
                                    Họ và Tên <span class="text-danger">*</span>
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light text-secondary"><i class="bi bi-person"></i></span>
                                    <input type="text" class="form-control" id="FullName" name="FullName" value="@Model?.FullName" placeholder="Nguyễn Văn A" required />
                                </div>
                            </div>

                            <!-- Email -->
                            <div class="col-md-6 mb-3">
                                <label for="Email" class="form-label font-weight-bold text-secondary">
                                    Email <span class="text-danger">*</span>
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light text-secondary"><i class="bi bi-envelope"></i></span>
                                    <input type="email" class="form-control" id="Email" name="Email" value="@Model?.Email" placeholder="email@example.com" required />
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <!-- Số điện thoại -->
                            <div class="col-md-6 mb-3">
                                <label for="Phone" class="form-label font-weight-bold text-secondary">Số Điện Thoại</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light text-secondary"><i class="bi bi-telephone"></i></span>
                                    <input type="tel" class="form-control" id="Phone" name="Phone" value="@Model?.Phone" placeholder="0901234567" />
                                </div>
                            </div>
                            
                            <!-- Mật khẩu -->
                            <div class="col-md-6 mb-3">
                                <label for="Password" class="form-label font-weight-bold text-secondary">
                                    Mật Khẩu <span class="text-danger">*</span>
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light text-secondary"><i class="bi bi-lock"></i></span>
                                    <input type="password" class="form-control" id="Password" name="Password" placeholder="Nhập mật khẩu..." required />
                                </div>
                            </div>
                        </div>

                        <!-- Địa chỉ -->
                        <div class="mb-4">
                            <label for="Address" class="form-label font-weight-bold text-secondary">Địa Chỉ</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light text-secondary"><i class="bi bi-geo-alt"></i></span>
                                <textarea class="form-control" id="Address" name="Address" rows="3" placeholder="Nhập địa chỉ của khách hàng...">@Model?.Address</textarea>
                            </div>
                        </div>

                        <!-- Hành động -->
                        <div class="d-flex justify-content-between align-items-center">
                            <a href="@Url.Action("Index", "Customer")" class="btn btn-outline-secondary px-4 py-2 rounded-pill">
                                <i class="bi bi-arrow-left me-1"></i> Quay lại
                            </a>
                            <button type="submit" class="btn btn-primary px-4 py-2 rounded-pill shadow-sm">
                                <i class="bi bi-check-circle-fill me-1"></i> Lưu khách hàng
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-lg  { border-radius: 16px !important; }
    .rounded-top { border-top-left-radius: 16px !important; border-top-right-radius: 16px !important; }
</style>
