@model List<CMS.Data.entities.Customer>

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản Lý Khách Hàng";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom border-primary">
        <h2 class="mb-0 text-primary font-weight-bold text-uppercase">
            <i class="bi bi-person-heart me-2"></i>Quản Lý Khách Hàng
        </h2>
        <a href="@Url.Action("Create", "Customer")" class="btn btn-primary px-4 py-2 rounded-pill shadow-sm">
            <i class="bi bi-plus-circle-fill me-2"></i>Thêm Khách Hàng Mới
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm rounded" role="alert">
            <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.Count == 0)
    {
        <div class="alert alert-info text-center py-5 shadow-sm rounded-lg" role="alert">
            <i class="bi bi-info-circle-fill fs-1 text-info mb-3 d-block"></i>
            <h4 class="alert-heading">Chưa có khách hàng nào!</h4>
            <p class="mb-0 text-muted">Nhấn nút "Thêm Khách Hàng Mới" phía trên để tạo khách hàng đầu tiên.</p>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-lg overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th scope="col" style="width:6%;">ID</th>
                            <th scope="col" style="width:22%;">Họ Và Tên</th>
                            <th scope="col" style="width:24%;">Email</th>
                            <th scope="col" style="width:16%;">Số Điện Thoại</th>
                            <th scope="col" style="width:16%;">Địa Chỉ</th>
                            <th scope="col" style="width:16%;" class="text-center">Hành Động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var customer in Model)
                        {
                            <tr>
                                <th scope="row">@customer.Id</th>
                                <td>
                                    <i class="bi bi-person-circle text-primary me-2"></i>
                                    <strong>@customer.FullName</strong>
                                </td>
                                <td class="text-muted">
                                    <i class="bi bi-envelope me-1"></i>@customer.Email
                                </td>
                                <td class="text-muted">
                                    <i class="bi bi-telephone me-1"></i>@customer.Phone
                                </td>
                                <td class="text-muted">@(string.IsNullOrEmpty(customer.Address) ? "—" : customer.Address)</td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a href="@Url.Action("Details", "Customer", new { id = customer.Id })"
                                           class="btn btn-outline-info btn-sm rounded me-1">
                                            <i class="bi bi-eye me-1"></i>Chi tiết
                                        </a>
                                        <a href="@Url.Action("Edit", "Customer", new { id = customer.Id })"
                                           class="btn btn-outline-warning btn-sm rounded me-1">
                                            <i class="bi bi-pencil-square me-1"></i>Sửa
                                        </a>
                                        <a href="@Url.Action("Delete", "Customer", new { id = customer.Id })"
                                           class="btn btn-outline-danger btn-sm rounded"
                                           onclick="return confirm('Bạn có chắc muốn xóa khách hàng &ldquo;@customer.FullName&rdquo; không?')">
                                            <i class="bi bi-trash-fill me-1"></i>Xóa
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<style>
    .rounded-lg { border-radius: 12px !important; }
</style>
