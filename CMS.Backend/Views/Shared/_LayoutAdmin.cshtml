<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ThaiCMS Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
        body {
            min-height: 100vh;
            background-color: #f1f3f5;
        }
        .sidebar {
            min-height: 100vh;
            background-color: #212529;
            color: white;
        }
        .sidebar a {
            color: #adb5bd;
            text-decoration: none;
            display: block;
            padding: 14px 20px;
        }
        .sidebar a:hover,
        .sidebar a.active {
            background-color: #0d6efd;
            color: white;
        }
        .sidebar .brand {
            padding: 24px 20px;
            border-bottom: 1px solid rgba(255,255,255,.08);
        }
        .sidebar .section-title {
            padding: 16px 20px 6px;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: .08em;
            color: #6c757d;
        }
        .admin-header {
            background-color: white;
            border-bottom: 1px solid #dee2e6;
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row g-0">
            <nav class="col-md-3 col-lg-2 sidebar p-0 shadow-sm">
                <div class="brand text-center text-white bg-dark">
                    <h4 class="mb-0">ThaiCMS Admin</h4>
                </div>
                <div class="section-title">Quản lý</div>
                <a asp-controller="Home" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Bảng điều khiển</a>
                <a asp-controller="Category" asp-action="Index"><i class="bi bi-grid me-2"></i>Quản lý Danh mục</a>
                <a asp-controller="Post" asp-action="Index"><i class="bi bi-file-earmark-post me-2"></i>Quản lý Bài viết</a>
                <a asp-controller="User" asp-action="Index"><i class="bi bi-people me-2"></i>Quản lý Thành viên</a>
            </nav>
            <main class="col-md-9 col-lg-10 ms-sm-auto p-4">
                <header class="admin-header py-3 mb-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h1 class="h4 mb-0">@ViewData["Title"]</h1>
                        </div>
                        <div class="text-muted small">
                            <i class="bi bi-person-circle me-1"></i>Admin
                        </div>
                    </div>
                </header>
                @RenderBody()
            </main>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>