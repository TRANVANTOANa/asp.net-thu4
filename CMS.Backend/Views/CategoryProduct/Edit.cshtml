@model CMS.Data.entities.CategoryProduct

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Cập Nhật Danh Mục Sản Phẩm";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-lg rounded-lg">
                <div class="card-header bg-warning text-dark text-center py-4 rounded-top">
                    <h3 class="card-title mb-0 text-uppercase font-weight-bold">
                        <i class="bi bi-pencil-square me-2"></i>Cập Nhật Danh Mục
                    </h3>
                    <p class="mb-0 mt-1" style="color:rgba(0,0,0,.6);">Chỉnh sửa thông tin danh mục dưới đây</p>
                </div>
                <div class="card-body p-4">
                    <form method="post" class="needs-validation">
                        @Html.AntiForgeryToken()
                        @Html.HiddenFor(m => m.Id)

                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger rounded mb-4">
                                <i class="bi bi-exclamation-triangle me-2"></i><strong>Có lỗi:</strong>
                                <ul class="mb-0 mt-2">
                                    @foreach (var ms in ViewData.ModelState.Values)
                                    {
                                        @foreach (var err in ms.Errors)
                                        {
                                            <li>@err.ErrorMessage</li>
                                        }
                                    }
                                </ul>
                            </div>
                        }

                        <!-- Tên danh mục -->
                        <div class="mb-3">
                            <label for="Name" class="form-label font-weight-bold text-secondary">
                                Tên Danh Mục <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-light text-secondary"><i class="bi bi-tag"></i></span>
                                <input type="text" class="form-control" id="Name" name="Name" value="@Model.Name" required />
                            </div>
                        </div>

                        <!-- Mô tả -->
                        <div class="mb-4">
                            <label for="Description" class="form-label font-weight-bold text-secondary">Mô Tả Danh Mục</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light text-secondary"><i class="bi bi-chat-left-text"></i></span>
                                <textarea class="form-control" id="Description" name="Description" rows="4">@Model.Description</textarea>
                            </div>
                        </div>

                        <!-- Hành động -->
                        <div class="d-flex justify-content-between align-items-center">
                            <a href="@Url.Action("Index", "CategoryProduct")" class="btn btn-outline-secondary px-4 py-2 rounded-pill">
                                <i class="bi bi-arrow-left me-1"></i> Quay lại
                            </a>
                            <button type="submit" class="btn btn-warning text-dark px-4 py-2 rounded-pill shadow-sm font-weight-bold">
                                <i class="bi bi-save-fill me-1"></i> Cập nhật thay đổi
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-lg  { border-radius: 16px !important; }
    .rounded-top { border-top-left-radius: 16px !important; border-top-right-radius: 16px !important; }
</style>
