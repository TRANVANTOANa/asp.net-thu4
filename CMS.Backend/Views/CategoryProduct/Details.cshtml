@model CMS.Data.entities.CategoryProduct

@{
    ViewData["Title"] = "Chi tiết danh mục sản phẩm";
}

<div class="container-fluid">
    <div class="row mb-3">
        <div class="col-md-6">
            <h1>@Model.Name</h1>
        </div>
        <div class="col-md-6 text-end">
            <a href="@Url.Action("Edit", "CategoryProduct", new { id = Model.Id })" class="btn btn-warning">
                <i class="bi bi-pencil"></i> Sửa
            </a>
            <a href="@Url.Action("Index", "CategoryProduct")" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card mb-3">
                <div class="card-body">
                    <h5 class="card-title">Thông tin danh mục</h5>

                    <div class="mb-3">
                        <label class="form-label"><strong>ID:</strong></label>
                        <p>@Model.Id</p>
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Tên danh mục:</strong></label>
                        <p>@Model.Name</p>
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Mô tả:</strong></label>
                        <p>@(string.IsNullOrEmpty(Model.Description) ? "Không có" : Model.Description)</p>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Danh sách sản phẩm</h5>

                    @if (Model.Products != null && Model.Products.Count > 0)
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-striped">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Tên sản phẩm</th>
                                        <th>Giá</th>
                                        <th>Kho</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var product in Model.Products)
                                    {
                                        <tr>
                                            <td>@product.Id</td>
                                            <td>@product.Name</td>
                                            <td>@product.Price.ToString("C")</td>
                                            <td>@product.StockQuantity</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">Chưa có sản phẩm nào trong danh mục này</p>
                    }
                </div>
            </div>

            <div class="mt-3">
                <a href="@Url.Action("Edit", "CategoryProduct", new { id = Model.Id })" class="btn btn-warning">
                    <i class="bi bi-pencil"></i> Sửa danh mục
                </a>
                <a href="@Url.Action("Delete", "CategoryProduct", new { id = Model.Id })" class="btn btn-danger"
                   onclick="return confirm('Bạn chắc chắn muốn xóa danh mục này?')">
                    <i class="bi bi-trash"></i> Xóa danh mục
                </a>
            </div>
        </div>
    </div>
</div>
