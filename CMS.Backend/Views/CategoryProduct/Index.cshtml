@model List<CMS.Data.entities.CategoryProduct>

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản Lý Danh Mục Sản Phẩm";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom border-primary">
        <h2 class="mb-0 text-primary font-weight-bold text-uppercase">
            <i class="bi bi-tags-fill me-2"></i>Quản Lý Danh Mục Sản Phẩm
        </h2>
        <a href="@Url.Action("Create", "CategoryProduct")" class="btn btn-primary px-4 py-2 rounded-pill shadow-sm">
            <i class="bi bi-plus-circle-fill me-2"></i>Thêm Danh Mục Mới
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm rounded" role="alert">
            <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.Count == 0)
    {
        <div class="alert alert-info text-center py-5 shadow-sm rounded-lg" role="alert">
            <i class="bi bi-info-circle-fill fs-1 text-info mb-3 d-block"></i>
            <h4 class="alert-heading">Chưa có danh mục sản phẩm nào!</h4>
            <p class="mb-0 text-muted">Nhấn nút "Thêm Danh Mục Mới" phía trên để tạo danh mục đầu tiên.</p>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-lg overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th scope="col" style="width:10%;">ID</th>
                            <th scope="col" style="width:35%;">Tên Danh Mục</th>
                            <th scope="col" style="width:35%;">Mô Tả</th>
                            <th scope="col" style="width:20%;" class="text-center">Hành Động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cat in Model)
                        {
                            <tr>
                                <th scope="row">@cat.Id</th>
                                <td>
                                    <i class="bi bi-tag text-warning me-2"></i>
                                    <strong>@cat.Name</strong>
                                </td>
                                <td class="text-muted">@cat.Description</td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a href="@Url.Action("Edit", "CategoryProduct", new { id = cat.Id })"
                                           class="btn btn-outline-warning btn-sm me-1 rounded">
                                            <i class="bi bi-pencil-square me-1"></i>Sửa
                                        </a>
                                        <a href="@Url.Action("Delete", "CategoryProduct", new { id = cat.Id })"
                                           class="btn btn-outline-danger btn-sm rounded"
                                           onclick="return confirm('Bạn có chắc muốn xóa danh mục &ldquo;@cat.Name&rdquo; không?')">
                                            <i class="bi bi-trash-fill me-1"></i>Xóa
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<style>
    .rounded-lg { border-radius: 12px !important; }
</style>
