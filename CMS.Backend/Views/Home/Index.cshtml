@model IEnumerable<CMS.Data.Entities.Post>

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Trang Chủ - CMS";
}

<div class="p-5 mb-5 rounded-3 text-white position-relative overflow-hidden"
     style="background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%) !important;">
    <div class="container-fluid py-5 position-relative z-index-1">
        <h1 class="display-4 font-weight-bold mb-3">Chào mừng bạn đến với Cổng Thông Tin CMS</h1>
        <p class="col-md-8 fs-4 mb-4">Hệ thống quản lý nội dung hiện đại, cập nhật nhanh chóng các tin tức, bài viết công nghệ và xu hướng đời sống xã hội mới nhất.</p>
        <div>
            <a href="/Post" class="btn btn-warning btn-lg px-4 rounded-pill font-weight-bold shadow-sm me-2">
                <i class="bi bi-book-half me-1"></i> Khám phá bài viết
            </a>
            <a href="/Category" class="btn btn-outline-light btn-lg px-4 rounded-pill shadow-sm">
                <i class="bi bi-grid-fill me-1"></i> Quản lý danh mục
            </a>
        </div>
    </div>
    <div class="position-absolute end-0 bottom-0 opacity-10" style="font-size: 15rem; transform: translate(10%, 20%); pointer-events: none;">
        <i class="bi bi-cpu-fill"></i>
    </div>
</div>

<div class="container mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom border-primary">
        <h3 class="mb-0 text-primary font-weight-bold text-uppercase">
            <i class="bi bi-lightning-charge-fill text-warning me-1"></i>Bài Viết Mới Nhất
        </h3>
        <a href="/Post" class="text-decoration-none">
            Xem tất cả bài viết <i class="bi bi-arrow-right-short"></i>
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center py-5 shadow-sm rounded-3" role="alert">
            <i class="bi bi-journal-x fs-1 text-info mb-3 d-block"></i>
            <h4 class="alert-heading">Chưa có bài viết nào!</h4>
            <p class="mb-0 text-muted">Vui lòng thêm danh mục và bài viết để xem nội dung hiển thị.</p>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 border-0 shadow-sm transition-card hover-shadow">
                        <div class="position-relative">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" class="card-img-top" alt="@item.Title" style="height: 220px; object-fit: cover;">
                            }
                            else
                            {
                                <div class="bg-light d-flex align-items-center justify-content-center" style="height: 220px;">
                                    <i class="bi bi-image text-muted" style="font-size: 3rem;"></i>
                                </div>
                            }
                            <span class="position-absolute top-0 start-0 m-3 badge bg-info text-dark px-3 py-2 shadow-sm font-weight-bold">
                                <i class="bi bi-tag-fill me-1"></i>@item.Category?.Name
                            </span>
                        </div>
                        <div class="card-body d-flex flex-column p-4">
                            <h5 class="card-title text-primary font-weight-bold mb-3 line-clamp-2" style="height: 3rem; overflow: hidden;">
                                @item.Title
                            </h5>
                            <p class="card-text text-muted mb-4 line-clamp-3" style="height: 4.5rem; overflow: hidden; font-size: 0.95rem;">
                                @item.Content
                            </p>
                            <div class="mt-auto pt-3 border-top border-light d-flex justify-content-between align-items-center">
                                <small class="text-muted">
                                    <i class="bi bi-calendar3 me-1"></i> @item.CreatedDate.ToString("dd/MM/yyyy")
                                </small>
                                <a href="/Post/Details/@item.Id" class="btn btn-outline-primary btn-sm px-3 rounded-pill">
                                    Đọc tiếp <i class="bi bi-arrow-right-short ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .transition-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .hover-shadow:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1.5rem rgba(0,0,0,.15) !important;
    }

    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>