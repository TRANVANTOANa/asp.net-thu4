@model IEnumerable<CMS.Data.Entities.User>

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản Lý Thành Viên";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom border-primary">
        <h2 class="mb-0 text-primary font-weight-bold text-uppercase">
            <i class="bi bi-people-fill me-2"></i>Quản Lý Thành Viên
        </h2>
        <a asp-action="Create" class="btn btn-primary px-4 py-2 rounded-pill shadow-sm">
            <i class="bi bi-plus-circle-fill me-2"></i>Thêm Thành Viên Mới
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center py-5 shadow-sm rounded-lg" role="alert">
            <i class="bi bi-info-circle-fill fs-1 text-info mb-3 d-block"></i>
            <h4 class="alert-heading">Chưa có thành viên nào!</h4>
            <p class="mb-0 text-muted">Nhấn nút "Thêm Thành Viên Mới" phía trên để tạo tài khoản đầu tiên.</p>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-lg overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th scope="col" style="width: 8%;">ID</th>
                            <th scope="col" style="width: 22%;">Tên Đăng Nhập</th>
                            <th scope="col" style="width: 32%;">Họ Và Tên</th>
                            <th scope="col" style="width: 18%;" class="text-center">Vai Trò</th>
                            <th scope="col" style="width: 20%;" class="text-center">Hành Động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <th scope="row">@user.Id</th>
                                <td>
                                    <i class="bi bi-person-circle text-primary me-2"></i>
                                    <strong>@user.Username</strong>
                                </td>
                                <td class="text-muted">@user.FullName</td>
                                <td class="text-center">
                                    @if (user.Role == "Admin")
                                    {
                                        <span class="badge rounded-pill px-3 py-2"
                                              style="background: linear-gradient(135deg,#667eea,#764ba2);">
                                            <i class="bi bi-shield-fill me-1"></i>Quản Trị Viên
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill px-3 py-2"
                                              style="background: linear-gradient(135deg,#11998e,#38ef7d); color:#fff;">
                                            <i class="bi bi-pencil-fill me-1"></i>Biên Tập Viên
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Edit" asp-route-id="@user.Id"
                                           class="btn btn-outline-warning btn-sm me-1 rounded">
                                            <i class="bi bi-pencil-square me-1"></i>Sửa
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@user.Id"
                                           class="btn btn-outline-danger btn-sm rounded"
                                           onclick="return confirm('Bạn có chắc muốn xóa thành viên &ldquo;@user.Username&rdquo; không?');">
                                            <i class="bi bi-trash-fill me-1"></i>Xóa
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<style>
    .rounded-lg { border-radius: 12px !important; }
</style>
