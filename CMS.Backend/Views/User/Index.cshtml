@model IEnumerable<CMS.Data.Entities.User>

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Danh sách thành viên";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom border-primary">
        <h2 class="mb-0 text-primary font-weight-bold text-uppercase">
            <i class="bi bi-people-fill me-2"></i>Danh Sách Thành Viên Quản Trị
        </h2>
        <a asp-action="Create" class="btn btn-success px-4 py-2 rounded-pill shadow-sm">
            <i class="bi bi-plus-circle me-1"></i>Thêm thành viên mới
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-lg overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th scope="col" style="width: 8%;">ID</th>
                        <th scope="col" style="width: 28%;">Tài khoản</th>
                        <th scope="col" style="width: 34%;">Họ và tên</th>
                        <th scope="col" style="width: 18%;" class="text-center">Vai trò</th>
                        <th scope="col" style="width: 12%;" class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <th scope="row">@user.Id</th>
                            <td class="font-weight-bold">@user.Username</td>
                            <td>@user.FullName</td>
                            <td class="text-center">
                                <span class="badge bg-primary px-3 py-2 rounded-pill">
                                    <i class="bi bi-shield-lock-fill me-1"></i>@user.Role
                                </span>
                            </td>
                            <td class="text-center">
                                <div class="btn-group" role="group">
                                    <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-outline-warning btn-sm">
                                        Sửa
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-outline-danger btn-sm" onclick="return confirm('Bạn có chắc chắn muốn xóa thành viên @user.Username không?')">
                                        Xóa
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
