@model CMS.Data.Entities.User

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Cập Nhật Thành Viên";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">
            <div class="card border-0 shadow-lg rounded-lg">
                <div class="card-header bg-warning text-dark text-center py-4 rounded-top">
                    <h3 class="card-title mb-0 text-uppercase font-weight-bold">
                        <i class="bi bi-pencil-square me-2"></i>Cập Nhật Thành Viên
                    </h3>
                    <p class="mb-0 mt-1" style="color:rgba(0,0,0,.6);">Chỉnh sửa thông tin tài khoản bên dưới</p>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />

                        <div class="row">
                            <!-- Tên đăng nhập (readonly) -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="Username" class="form-label font-weight-bold text-secondary">
                                    Tên Đăng Nhập
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light text-secondary">
                                        <i class="bi bi-person"></i>
                                    </span>
                                    <input asp-for="Username" class="form-control bg-light" readonly />
                                </div>
                                <small class="text-muted">Tên đăng nhập không được phép thay đổi.</small>
                            </div>

                            <!-- Mật khẩu mới -->
                            <div class="col-md-6 mb-3">
                                <label class="form-label font-weight-bold text-secondary">Mật Khẩu Mới</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light text-secondary">
                                        <i class="bi bi-lock"></i>
                                    </span>
                                    <input type="password" name="NewPassword" class="form-control"
                                           placeholder="Để trống nếu không muốn đổi" />
                                </div>
                                <small class="text-muted">Bỏ trống nếu giữ nguyên mật khẩu cũ.</small>
                            </div>
                        </div>

                        <div class="row">
                            <!-- Họ và tên -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="FullName" class="form-label font-weight-bold text-secondary">
                                    Họ Và Tên <span class="text-danger">*</span>
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light text-secondary">
                                        <i class="bi bi-card-text"></i>
                                    </span>
                                    <input asp-for="FullName" class="form-control" required />
                                </div>
                                <span asp-validation-for="FullName" class="text-danger small"></span>
                            </div>

                            <!-- Vai trò -->
                            <div class="col-md-6 mb-4">
                                <label asp-for="Role" class="form-label font-weight-bold text-secondary">
                                    Vai Trò <span class="text-danger">*</span>
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light text-secondary">
                                        <i class="bi bi-shield-lock"></i>
                                    </span>
                                    <select asp-for="Role" class="form-select" required>
                                        <option value="Admin">Quản Trị Viên (Admin)</option>
                                        <option value="Editor">Biên Tập Viên (Editor)</option>
                                    </select>
                                </div>
                                <span asp-validation-for="Role" class="text-danger small"></span>
                            </div>
                        </div>

                        <!-- Hành động -->
                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2 rounded-pill">
                                <i class="bi bi-arrow-left me-1"></i> Quay lại
                            </a>
                            <button type="submit" class="btn btn-warning text-dark px-4 py-2 rounded-pill shadow-sm font-weight-bold">
                                <i class="bi bi-save-fill me-1"></i> Cập nhật thay đổi
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-lg  { border-radius: 16px !important; }
    .rounded-top { border-top-left-radius: 16px !important; border-top-right-radius: 16px !important; }
</style>